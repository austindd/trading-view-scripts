//@version=5
indicator("Price Acceptance Candles [SB]", "PAC [SB]", overlay=true, max_labels_count=500)

// ───────── Inputs ─────────
ltf           = input.timeframe("5",    "Lower Timeframe",
     tooltip="LTF used to analyse the distribution of price inside each HTF candle.")
maxWickRatio  = input.float(0.25,       "Max Wick / Body Ratio", minval=0.01, step=0.05,
     tooltip="Maximum allowed wick size as a fraction of the body.")
useTotalWick  = input.bool(true,        "Sum Both Wicks (else use largest single wick)",
     tooltip="On: (upper + lower) ≤ ratio × body. Off: max(upper, lower) ≤ ratio × body.")
skewThreshold = input.float(0.60,       "Skew Threshold", minval=0.50, maxval=1.0, step=0.05,
     tooltip="Fraction of LTF closes that must fall in the favoured half (top for bull, bottom for bear).")
minLtfBars    = input.int(3,            "Minimum LTF Bars Required", minval=1,
     tooltip="Reject the signal if fewer than this many LTF bars are available.")
bullColor     = input.color(color.lime, "Bullish Marker")
bearColor     = input.color(color.red,  "Bearish Marker")
paintBars     = input.bool(true,        "Color Qualifying Bars")

// ───────── Body / wick check ─────────
body        = math.abs(close - open)
upperWick   = high - math.max(open, close)
lowerWick   = math.min(open, close) - low
wickMeasure = useTotalWick ? upperWick + lowerWick : math.max(upperWick, lowerWick)
wickOk      = body > 0 and (wickMeasure / body) <= maxWickRatio

isBull = close > open
isBear = close < open

// ───────── LTF distribution ─────────
// Pulls every LTF close that occurred inside the current HTF bar.
ltfCloses = request.security_lower_tf(syminfo.tickerid, ltf, close)
midpoint  = (high + low) / 2.0

float topCount = 0
float botCount = 0

if array.size(ltfCloses) > 0
    for i = 0 to array.size(ltfCloses) - 1
        c = array.get(ltfCloses, i)
        if c > midpoint
            topCount := topCount + 1
        else if c < midpoint
            botCount := botCount + 1

totalLtf = topCount + botCount
topRatio = totalLtf > 0 ? topCount / totalLtf : 0.0
botRatio = totalLtf > 0 ? botCount / totalLtf : 0.0

// ───────── Signals ─────────
bullSignal = isBull and wickOk and topRatio >= skewThreshold and totalLtf >= minLtfBars
bearSignal = isBear and wickOk and botRatio >= skewThreshold and totalLtf >= minLtfBars

// ───────── Plot ─────────
plotshape(bullSignal, "Bullish Acceptance", shape.triangleup,
     location.belowbar, bullColor, size=size.small)
plotshape(bearSignal, "Bearish Acceptance", shape.triangledown,
     location.abovebar, bearColor, size=size.small)
barcolor(paintBars ? (bullSignal ? bullColor : bearSignal ? bearColor : na) : na)

// ───────── Alerts ─────────
alertcondition(bullSignal, "Bullish Price Acceptance", "Bullish price-acceptance candle")
alertcondition(bearSignal, "Bearish Price Acceptance", "Bearish price-acceptance candle")
