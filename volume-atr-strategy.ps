//@version=5
strategy("Volume + ATR/ADR Strategy", overlay=true,
  process_orders_on_close=true,
  default_qty_type=strategy.percent_of_equity, default_qty_value=100,
  initial_capital=10000)

// ═══════════════════════════════════════════════════════════
// ── Strategy Settings ──
// ═══════════════════════════════════════════════════════════
var gStrat = "Strategy"
rrRatio     = input.float(1.0, "Risk:Reward Ratio", minval=0.1, step=0.1, group=gStrat,
               tooltip="Take profit distance as a multiple of risk (stop distance)")
dirFilter   = input.string("Both", "Direction", options=["Both", "Long Only", "Short Only"], group=gStrat)
minAtrMult  = input.float(1.0, "Min ATR/ADR Multiple", minval=0.0, step=0.1, group=gStrat,
               tooltip="Candle move must be at least this multiple of ATR/ADR to qualify")
maxAtrMult  = input.float(999.0, "Max ATR/ADR Multiple", minval=0.1, step=0.1, group=gStrat,
               tooltip="Candle move must be at most this multiple of ATR/ADR to qualify")
maxVolRatio = input.float(999.0, "Max Volume Ratio", minval=0.1, step=0.1, group=gStrat,
               tooltip="Volume must be at most this multiple of the baseline to qualify")

// ═══════════════════════════════════════════════════════════
// ── Body Settings ──
// ═══════════════════════════════════════════════════════════
var gBody = "Body"
minBodyRatio = input.float(0.75, "Min Body/Range Ratio", minval=0.0, maxval=1.0, step=0.05, group=gBody)

// ═══════════════════════════════════════════════════════════
// ── Volume Settings ──
// ═══════════════════════════════════════════════════════════
var gVol = "Volume"
volMode     = input.string("Previous Bars", "Volume Threshold Mode", options=["Previous Bars", "Moving Average"], group=gVol)
minVolRatio = input.float(2.0, "Min Volume Ratio", minval=0.0, step=0.1, group=gVol)

var gVolPrev = "Volume — Previous Bars"
prevBars     = input.int(1, "Previous Bars Count", minval=1, maxval=20, group=gVolPrev)

var gVolMA = "Volume — Moving Average"
maType   = input.string("SMA", "MA Type", options=["SMA", "EMA", "WMA", "SWMA", "DEMA", "TEMA", "HMA"], group=gVolMA)
maLength = input.int(20, "MA Lookback", minval=1, group=gVolMA)

// ═══════════════════════════════════════════════════════════
// ── ATR/ADR Settings ──
// ═══════════════════════════════════════════════════════════
var gAtr = "ATR/ADR Settings"
adrOrAtr    = input.string('ATR', 'ATR or ADR', options=['ATR', 'ADR'], group=gAtr)
atrLenLong  = input.int(20, 'ATR/ADR Long Lookback', group=gAtr)
atrLenShort = input.int(5, 'ATR/ADR Short Lookback', group=gAtr)
bgColorBool = input.bool(true, ' ', inline='bg1', group=gAtr)
bgColor     = input.color(color.new(color.yellow, 90), 'Show ATR/ADR Expansion', inline='bg1', group=gAtr,
               tooltip='Color background when Short ATR/ADR > Long ATR/ADR')

var gCandle = "Candle Colors"
atrLenMed = input.int(10, 'ATR/ADR Length for Candles', group=gCandle,
             tooltip='ATR length used to calculate candle colors and strategy qualification')
atrSrc    = input.string('Open', 'Calculate ATR Move From', options=['Open', 'Previous Close', 'Daily Range'],
             group=gCandle, tooltip='Calculate the ATR move from the open, previous close, or full daily range. ADR always uses daily range.')
fullAtrBool = input.bool(true, ' ', inline='c1', group=gCandle)
contraBool  = input.bool(true, ' ', inline='c2', group=gCandle)
expan1Bool  = input.bool(true, ' ', inline='c3', group=gCandle)
expan2Bool  = input.bool(true, ' ', inline='c4', group=gCandle)

contractMult = input.float(0.5, 'Contraction Threshold', minval=0.1, maxval=0.99, step=0.01, inline='c2',
                group=gCandle, tooltip='A candle whose range is less than this % of ATR/ADR')
multi2       = input.float(1.5, 'Expansion Threshold', minval=1.25, maxval=10, step=0.25, inline='c3',
                group=gCandle, tooltip='A candle whose range is greater than this % of ATR/ADR')
multi3       = input.float(2.0, 'Expansion Threshold', minval=1.5, maxval=10, step=0.25, inline='c4',
                group=gCandle, tooltip='A candle whose range is greater than this % of ATR/ADR')

color1 = input.color(color.rgb(255, 213, 151), 'Full ATR/ADR', inline='c1', group=gCandle)
color2 = input.color(color.rgb(179, 246, 255), ' ', inline='c2', group=gCandle)
color3 = input.color(color.rgb(34, 130, 255), ' ', inline='c3', group=gCandle)
color4 = input.color(color.rgb(255, 0, 119), ' ', inline='c4', group=gCandle)

var gRange = "Ranges"
showLines  = input.bool(false, 'Show Expansion Candle Open/Close', inline='r1', group=gRange)
onlyLast   = input.bool(false, 'Only Show Last Lines', inline='r1', group=gRange)
maxLineLen = input.int(9, 'Delete Lines After Bars', inline='r2', group=gRange)
lineStyle  = input.string('Solid', 'Line Style', options=['Solid', 'Dashed', 'Dotted'], inline='r3', group=gRange)
lineColor  = input.color(color.red, ' ', inline='r3', group=gRange)

var gLabel = "ATR Labels"
showAtrLabels = input.bool(true, ' ', inline='l1', group=gLabel)
yPos          = input.string("Bottom", "ATR/ADR Labels", options=["Top", "Middle", "Bottom"], inline='l1', group=gLabel)
xPos          = input.string("Right", " ", options=["Right", "Center", "Left"], inline='l1', group=gLabel)
labelColor    = input.color(color.new(color.white, 100), 'Label Color', inline='l2', group=gLabel)
textColor     = input.color(color.black, 'Text Color', inline='l2', group=gLabel)

// ═══════════════════════════════════════════════════════════
// ── Helper Functions ──
// ═══════════════════════════════════════════════════════════
method switcher(string this) =>
    switch this
        'Solid' => line.style_solid
        'Dashed' => line.style_dashed
        'Dotted' => line.style_dotted

calcMA(src, len, typ) =>
    switch typ
        "SMA"  => ta.sma(src, len)
        "EMA"  => ta.ema(src, len)
        "WMA"  => ta.wma(src, len)
        "SWMA" => ta.swma(src)
        "DEMA" =>
            e1 = ta.ema(src, len)
            2 * e1 - ta.ema(e1, len)
        "TEMA" =>
            e1 = ta.ema(src, len)
            e2 = ta.ema(e1, len)
            3 * e1 - 3 * e2 + ta.ema(e2, len)
        "HMA" =>
            halfLen = math.max(math.round(len / 2), 1)
            sqrtLen = math.max(math.round(math.sqrt(len)), 1)
            ta.wma(2 * ta.wma(src, halfLen) - ta.wma(src, len), sqrtLen)

// ═══════════════════════════════════════════════════════════
// ── Volume Calculations ──
// ═══════════════════════════════════════════════════════════
bodySize  = math.abs(close - open)
rangeSize = high - low
bodyRatio = rangeSize > 0 ? bodySize / rangeSize : 0.0

float volRatio = 0.0
if volMode == "Previous Bars"
    float prevVolSum = 0.0
    for i = 1 to prevBars
        prevVolSum += volume[i]
    volRatio := prevVolSum > 0 ? volume / (prevVolSum / prevBars) : 0.0
else
    volMA = calcMA(volume, maLength, maType)
    volRatio := not na(volMA) and volMA > 0 ? volume / volMA : 0.0

// ═══════════════════════════════════════════════════════════
// ── ATR/ADR Calculations ──
// ═══════════════════════════════════════════════════════════
dailyRange = high - low
atrLong    = ta.atr(atrLenLong)
atrShort   = ta.atr(atrLenShort)
atrMed     = ta.atr(atrLenMed)
adrLong    = ta.sma(dailyRange, atrLenLong)
adrShort   = ta.sma(dailyRange, atrLenShort)
adrMed     = ta.sma(dailyRange, atrLenMed)

// Candle move based on source setting
float candleMove = 0.0
if adrOrAtr == 'ADR'
    candleMove := dailyRange
else if atrSrc == 'Open'
    candleMove := bodySize
else if atrSrc == 'Previous Close'
    candleMove := math.abs(close - close[1])
else
    candleMove := dailyRange

float baseAtr = adrOrAtr == 'ADR' ? adrMed : atrMed
float atrRatio = baseAtr > 0 ? candleMove / baseAtr : 0.0

// ATR candle classification (from original indicator)
contract1 = adrOrAtr == 'ADR' ? dailyRange <= adrMed * contractMult : adrOrAtr == 'ATR' ? close < open and atrSrc == 'Open' ? (open - close) <= atrMed * contractMult : close > open and atrSrc == 'Open' ? (close - open) <= atrMed * contractMult :
      close < close[1] and atrSrc == 'Previous Close' ? (close[1] - close) <= atrMed * contractMult : close > close[1] and atrSrc == 'Previous Close' ? (close - close[1]) <= atrMed * contractMult :
      atrSrc == 'Daily Range' ? dailyRange <= atrMed * contractMult : na : na
expan1 = adrOrAtr == 'ADR' ? dailyRange >= adrMed * multi2 : adrOrAtr == 'ATR' ? close < open and atrSrc == 'Open' ? (open - close) >= atrMed * multi2 : close > open and atrSrc == 'Open' ? (close - open) >= atrMed * multi2 :
      close < close[1] and atrSrc == 'Previous Close' ? (close[1] - close) >= atrMed * multi2 : close > close[1] and atrSrc == 'Previous Close' ? (close - close[1]) >= atrMed * multi2 :
      atrSrc == 'Daily Range' ? dailyRange >= atrMed * multi2 : na : na
expan2 = adrOrAtr == 'ADR' ? dailyRange >= adrMed * multi3 : adrOrAtr == 'ATR' ? close < open and atrSrc == 'Open' ? (open - close) >= atrMed * multi3 : close > open and atrSrc == 'Open' ? (close - open) >= atrMed * multi3 :
      close < close[1] and atrSrc == 'Previous Close' ? (close[1] - close) >= atrMed * multi3 : close > close[1] and atrSrc == 'Previous Close' ? (close - close[1]) >= atrMed * multi3 :
      atrSrc == 'Daily Range' ? dailyRange >= atrMed * multi3 : na : na
isFull = adrOrAtr == 'ADR' ? dailyRange >= adrMed : adrOrAtr == 'ATR' ? close < open and atrSrc == 'Open' ? (open - close) >= atrMed : close > open and atrSrc == 'Open' ? (close - open) >= atrMed :
      close < close[1] and atrSrc == 'Previous Close' ? (close[1] - close) >= atrMed : close > close[1] and atrSrc == 'Previous Close' ? (close - close[1]) >= atrMed :
      atrSrc == 'Daily Range' ? dailyRange >= atrMed : na : na
expansion = adrOrAtr == 'ATR' ? atrShort > atrLong : adrShort > adrLong
isExpan = expan1 or expan2

// ═══════════════════════════════════════════════════════════
// ── Combined Signal ──
// ═══════════════════════════════════════════════════════════
isVolQualified = bodyRatio >= minBodyRatio and volRatio >= minVolRatio and volRatio <= maxVolRatio
isAtrQualified = atrRatio >= minAtrMult and atrRatio <= maxAtrMult
isQualified    = isVolQualified and isAtrQualified
isBullish      = close >= open

// ═══════════════════════════════════════════════════════════
// ── Strategy Entries ──
// ═══════════════════════════════════════════════════════════
if isQualified and isBullish and (dirFilter == "Both" or dirFilter == "Long Only")
    float stopPrice = open - syminfo.mintick
    float risk = close - stopPrice
    float tpPrice = close + risk * rrRatio
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=stopPrice, limit=tpPrice)

if isQualified and not isBullish and (dirFilter == "Both" or dirFilter == "Short Only")
    float stopPrice = open + syminfo.mintick
    float risk = stopPrice - close
    float tpPrice = close - risk * rrRatio
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=stopPrice, limit=tpPrice)

// ═══════════════════════════════════════════════════════════
// ── Visuals ──
// ═══════════════════════════════════════════════════════════
// Bar coloring (ATR/ADR classification)
barcolor(expan2 and expan2Bool ? color4 : expan1 and expan1Bool ? color3 : isFull and fullAtrBool ? color1 :
       contract1 and contraBool ? color2 : na)
bgcolor(expansion and bgColorBool ? bgColor : na)

// Qualifying candle markers
plotshape(isQualified and isBullish, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small)
plotshape(isQualified and not isBullish, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small)

// ATR/ADR info table
var table atrTable = table.new(str.lower(yPos) + '_' + str.lower(xPos), 1, 4,
      border_color=color.new(color.white, 100), border_width=2)

if barstate.islast and showAtrLabels
    table.cell(atrTable, 0, 0, ' ', bgcolor=color.new(color.white, 100))
    table.cell(atrTable, 0, 1, adrOrAtr == 'ATR' ? 'ATR Long: $' + str.tostring(atrLong, format.mintick) : 'ADR Long: $' + str.tostring(adrLong, format.mintick),
      text_color=textColor, text_halign=text.align_left, bgcolor=labelColor)
    table.cell(atrTable, 0, 2, adrOrAtr == 'ATR' ? 'ATR Short: $' + str.tostring(atrShort, format.mintick) : 'ADR Short: $' + str.tostring(adrShort, format.mintick),
      text_color=textColor, text_halign=text.align_left, bgcolor=labelColor)
    table.cell(atrTable, 0, 3, ' ', bgcolor=color.new(color.white, 100))

// Expansion candle open/close lines
var line openLine = na, var line closeLine = na
var line[] openLinesArr = array.new_line()
var line[] closeLinesArr = array.new_line()

if isExpan and showLines
    openLine := line.new(bar_index, open, bar_index + 1, open, extend=extend.right, style=lineStyle.switcher(), color=lineColor)
    closeLine := line.new(bar_index, close, bar_index + 1, close, extend=extend.right, style=lineStyle.switcher(), color=lineColor)
    openLinesArr.unshift(openLine), closeLinesArr.unshift(closeLine)
    if onlyLast
        if not na(openLine[1])
            openLine[1].delete()
        if not na(closeLine[1])
            closeLine[1].delete()

for [ind, l] in openLinesArr
    if bar_index - l.get_x1() > maxLineLen
        line.delete(openLinesArr.get(ind))
for [ind, l] in closeLinesArr
    if bar_index - l.get_x1() > maxLineLen
        line.delete(closeLinesArr.get(ind))

// Alerts
if expansion and not expansion[1]
    alert('ATR/ADR Expansion', alert.freq_once_per_bar_close)
