//@version=5
indicator("MA-Filtered Strong Moves [SB]", "MA Strong Moves [SB]", overlay = true
  , max_bars_back = 5000
  , max_boxes_count  = 500)

////////////////////////////////////////////////////////////////////////////////
//// Inputs
////////////////////////////////////////////////////////////////////////////////
grp1 = 'Strong Move Detection'
grp2 = 'Moving Average Filter'
grp3 = 'Display Settings'
grp4 = 'Colors'

// Strong Move Detection
src 								= input.source(close, title='Source', group=grp1)
src_vol 							= input.string('No', title='Use volume as the source?', group=grp1, options=['No', 'Volume', 'VolumeDiff'], tooltip='If enabled, will use volume as the source, so the Source parameter above will be ignored.')
period 								= input.int(80, title='Lookback Period', minval=1, maxval=500, group=grp1, tooltip='This is the number of bars that will be sampled to detect outliers in the "Source" data.') + 1
limit_second 						= input.float(13, title='Significance threshold', minval=0, step=0.05, group=grp1, tooltip='This value is used as a threshold for detecting outliers in the "Source" data, which should identify significant "strong moves" in the price action. Generally speaking, the higher the value, the fewer zones will be detected. However, those zone tend to be higher quality. You probably want a value between 0.5 and 2.5')
minMoveToZoneRatioInput				= input.float(1.1, title='Minimum move to zone ratio', minval=0, step=0.05, group=grp1, tooltip='This is the minimum ratio of the strong move to the origin zone size. Filters out weak moves.')
maxNumberOfMovesInput				= input.int(120, title='Max number of moves', minval=1, group=grp1, tooltip='Maximum number of strong moves displayed on chart.')

// Moving Average Filter
maTypeInput							= input.string('EMA', title='MA Type', group=grp2, options=['EMA', 'SMA'], tooltip='Type of moving average to use as the trend filter.')
maLengthInput						= input.int(50, title='MA Length', minval=1, group=grp2, tooltip='Length of the moving average.')
maSourceInput						= input.source(close, title='MA Source', group=grp2, tooltip='Source for the moving average calculation.')
showMaInput							= input.bool(true, title='Show MA on Chart', group=grp2, tooltip='If enabled, plots the moving average on the chart.')

// Display Settings
showBearishMovesInput				= input.bool(true, title="Show Bearish Strong Moves", group=grp3)
showBullishMovesInput				= input.bool(true, title="Show Bullish Strong Moves", group=grp3)

// Colors
bearishMoveColorInput 				= input.color(color.new(color.red, 70), title="Bearish Strong Move Color", group=grp4)
bearishMoveBorderColorInput			= input.color(color.new(color.red, 40), title="Bearish Strong Move Border Color", group=grp4)
bullishMoveColorInput 				= input.color(color.new(color.green, 70), title="Bullish Strong Move Color", group=grp4)
bullishMoveBorderColorInput			= input.color(color.new(color.green, 40), title="Bullish Strong Move Border Color", group=grp4)
maColorInput						= input.color(color.new(color.yellow, 0), title="MA Color", group=grp4)

////////////////////////////////////////////////////////////////////////////////
//// Type Definitions
////////////////////////////////////////////////////////////////////////////////

type StrongMove
	int dir = na
	int startLoc = na
	int endLoc = na
	float startPrice = na
	float endPrice = na
	float totalChange = na
	float highPrice = na
	float lowPrice = na
	int numberOfBars = na

////////////////////////////////////////////////////////////////////////////////
//// Calculations
////////////////////////////////////////////////////////////////////////////////

// DATA LOADING
float source = switch src_vol
	"No" => src
	'Volume' => math.sign(ta.change(close)) * volume
	'VolumeDiff' => volume

// Z-score calculation
diff = src_vol == 'Volume' ? source : source[0] - math.avg(source[1], source[1], source[2])

sample = array.new<float>(period, 0.0)
for i = 0 to period - 1
	array.set(sample, i, diff[i])

sampleAvg = array.avg(sample)
sampleStdDev = array.stdev(sample, false)

z = (diff - sampleAvg) / (sampleStdDev / math.sqrt(period))
z_abs = math.abs(z)

limit_first = ta.highest(z_abs, period) / 2

// Candle calculations
candleBodyRange = math.abs(open - close)
candleRange = high - low
candleBodyUp = close > open
candleBodyDown = close < open

// Moving Average
maValue = maTypeInput == 'EMA' ? ta.ema(maSourceInput, maLengthInput) : ta.sma(maSourceInput, maLengthInput)

////////////////////////////////////////////////////////////////////////////////
//// Strong Move Arrays
////////////////////////////////////////////////////////////////////////////////

var bearishMoves = array.new<StrongMove>(0)
var bullishMoves = array.new<StrongMove>(0)

////////////////////////////////////////////////////////////////////////////////
//// Detection Functions
////////////////////////////////////////////////////////////////////////////////

identifyBearishMove() =>
	var StrongMove move = na
	var bool hasExplosiveCandle = false
	var float maxDeviation = 0
	prevMove = array.size(bearishMoves) > 0 ? array.get(bearishMoves, 0) : na
	prevMoveInProgress = not na(prevMove) ? prevMove.endLoc >= bar_index - 1 : false

	if z_abs > limit_first and candleBodyDown
		maxDeviation := math.max(z_abs, maxDeviation)
		move := StrongMove.new(dir=-1, startLoc=bar_index, endLoc=bar_index, startPrice=math.max(close[1], open), endPrice=close, totalChange=0, highPrice=math.max(close[1], high), lowPrice=low, numberOfBars=0)
		for i = 0 to 40
			explosiveCandle = z_abs[i] > limit_second and candleBodyDown[i] and candleBodyRange[i] / candleRange[i] > 0.4
			if explosiveCandle
				maxDeviation := math.max(z_abs[i], maxDeviation)
				move.startLoc := move.startLoc - 1
				move.startPrice := math.max(close[i + 1], open[i])
				move.highPrice := math.max(move.highPrice, close[i + 1], high[i])
				move.lowPrice := math.min(move.lowPrice, low[i])
				move.totalChange := move.endPrice - move.startPrice
				move.numberOfBars := move.numberOfBars + 1
				hasExplosiveCandle := true
			else
				break
		if not hasExplosiveCandle
			move := na
		else if prevMoveInProgress
			array.shift(bearishMoves)

	// Validate: compute origin zone and check move ratio + MA filter
	StrongMove result = na
	if not na(move)
		zoneTop = math.max(move.highPrice, high[move.numberOfBars])
		zoneBtm = math.min(move.startPrice, low[move.numberOfBars])
		zoneHeight = zoneTop - zoneBtm
		moveDistance = zoneBtm - move.endPrice
		originPrice = move.startPrice
		// MA filter: bearish move must originate below the MA
		maAtOrigin = maValue[bar_index - move.startLoc]
		passesRatio = zoneHeight > 0 and moveDistance / zoneHeight > minMoveToZoneRatioInput
		passesMaFilter = originPrice < maAtOrigin
		if passesRatio and passesMaFilter
			array.unshift(bearishMoves, move)
			result := move

	if array.size(bearishMoves) > maxNumberOfMovesInput
		array.pop(bearishMoves)

	move := na
	hasExplosiveCandle := false
	maxDeviation := 0
	result


identifyBullishMove() =>
	var StrongMove move = na
	var bool hasExplosiveCandle = false
	var float maxDeviation = 0
	prevMove = array.size(bullishMoves) > 0 ? array.get(bullishMoves, 0) : na
	prevMoveInProgress = not na(prevMove) ? prevMove.endLoc >= bar_index - 1 : false

	if z_abs > limit_first and candleBodyUp
		maxDeviation := math.max(z_abs, maxDeviation)
		move := StrongMove.new(dir=1, startLoc=bar_index, endLoc=bar_index, startPrice=math.min(close[1], open), endPrice=close, totalChange=0, highPrice=high, lowPrice=math.min(close[1], low), numberOfBars=0)
		for i = 0 to 40
			explosiveCandle = z_abs[i] > limit_second and candleBodyUp[i] and candleBodyRange[i] / candleRange[i] > 0.4
			if explosiveCandle
				maxDeviation := math.max(z_abs[i], maxDeviation)
				move.startLoc := move.startLoc - 1
				move.startPrice := math.min(close[i + 1], open[i])
				move.highPrice := math.max(move.highPrice, high[i])
				move.lowPrice := math.min(move.lowPrice, close[i + 1], low[i])
				move.totalChange := move.endPrice - move.startPrice
				move.numberOfBars := move.numberOfBars + 1
				hasExplosiveCandle := true
			else
				break
		if not hasExplosiveCandle
			move := na
		else if prevMoveInProgress
			array.shift(bullishMoves)

	// Validate: compute origin zone and check move ratio + MA filter
	StrongMove result = na
	if not na(move)
		zoneTop = math.max(move.startPrice, high[move.numberOfBars])
		zoneBtm = math.min(move.lowPrice, low[move.numberOfBars])
		zoneHeight = zoneTop - zoneBtm
		moveDistance = move.endPrice - zoneTop
		originPrice = move.startPrice
		// MA filter: bullish move must originate above the MA
		maAtOrigin = maValue[bar_index - move.startLoc]
		passesRatio = zoneHeight > 0 and moveDistance / zoneHeight > minMoveToZoneRatioInput
		passesMaFilter = originPrice > maAtOrigin
		if passesRatio and passesMaFilter
			array.unshift(bullishMoves, move)
			result := move

	if array.size(bullishMoves) > maxNumberOfMovesInput
		array.pop(bullishMoves)

	move := na
	hasExplosiveCandle := false
	maxDeviation := 0
	result

////////////////////////////////////////////////////////////////////////////////
//// Display Functions
////////////////////////////////////////////////////////////////////////////////

displayStrongMove(StrongMove move, color moveCss, color moveBorderCss) =>
	if bar_index - move.startLoc < 4000
		box.new(move.startLoc, move.highPrice, move.endLoc + 1, move.lowPrice, bgcolor = moveCss, border_color = moveBorderCss)

displayMoveList(array<StrongMove> moveList, color moveCss, color moveBorderCss) =>
	if barstate.islast
		if moveList.size() > 0
			for i = 0 to moveList.size() - 1
				move = moveList.get(i)
				displayStrongMove(move, moveCss, moveBorderCss)

////////////////////////////////////////////////////////////////////////////////
//// Main
////////////////////////////////////////////////////////////////////////////////

bearishMove = identifyBearishMove()
bullishMove = identifyBullishMove()

// Clear all boxes each bar (redrawn on last bar)
for bx in box.all
	bx.delete()

// Display strong moves
if showBearishMovesInput
	displayMoveList(bearishMoves, bearishMoveColorInput, bearishMoveBorderColorInput)
if showBullishMovesInput
	displayMoveList(bullishMoves, bullishMoveColorInput, bullishMoveBorderColorInput)

// Plot MA
plot(showMaInput ? maValue : na, title="Moving Average", color=maColorInput, linewidth=2)

////////////////////////////////////////////////////////////////////////////////
//// Alerts
////////////////////////////////////////////////////////////////////////////////

alertcondition(not na(bearishMove), title = "Bearish Strong Move", message = 'Bearish strong move detected below MA')
alertcondition(not na(bullishMove), title = "Bullish Strong Move", message = 'Bullish strong move detected above MA')
