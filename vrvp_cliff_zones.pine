//@version=5
indicator("Visual Range Volume Profile - Cliff Zones [SB]", shorttitle="VRVP Cliffs [SB]",
     overlay=true, max_boxes_count=500, max_labels_count=100, max_bars_back=5000)

// ─── Inputs ──────────────────────────────────────────────────────────
gP = "Profile"
numBins      = input.int(100,  "Number of Bins",            minval=20, maxval=500, group=gP)
useVisible   = input.bool(true,"Use Visible Range",                                group=gP, tooltip="If on, the profile recomputes from the bars currently visible on the chart. If off, uses a fixed lookback.")
lookback     = input.int(500,  "Lookback (fallback)",       minval=20,             group=gP)
profileWidth = input.int(25,   "Profile Width (% of bars)", minval=5, maxval=80,   group=gP)
showProfile  = input.bool(true,"Show Volume Profile",                              group=gP)
profileColor = input.color(color.new(color.blue, 70), "Profile Color",             group=gP)

gC = "Cliff Zones"
cliffRatio   = input.float(2.0, "Cliff Ratio (X)",          minval=1.2, step=0.1,  group=gC, tooltip="A cliff is flagged where one adjacent bin's volume is >= X times the other.")
minSig       = input.float(5.0, "Min Significance (% max)", minval=0, maxval=50, step=0.5, group=gC, tooltip="Cliff is ignored unless the high-volume side is at least this % of the max-volume bin. Filters edge noise.")
extendRight  = input.int(50,    "Extend Zones Right",       minval=0,              group=gC)
supplyColor  = input.color(color.new(color.red,   80),      "Supply (above price)",group=gC)
demandColor  = input.color(color.new(color.green, 80),      "Demand (below price)",group=gC)
extendToLocal= input.bool(false,"Extend to Local Peak/Trough",                     group=gC, tooltip="Expands each cliff zone to cover from the local volume trough (low-volume side) to the local volume peak (high-volume side).")
showBorder   = input.bool(true, "Show Zone Border",                                group=gC)
showLabel    = input.bool(true, "Show Ratio Label",                                group=gC)

// ─── Persistent storage ──────────────────────────────────────────────
var box[]   profBoxes  = array.new<box>()
var box[]   zoneBoxes  = array.new<box>()
var label[] zoneLabels = array.new<label>()

// ─── Helpers ─────────────────────────────────────────────────────────
clearAll() =>
    if array.size(profBoxes) > 0
        for i = 0 to array.size(profBoxes) - 1
            box.delete(array.get(profBoxes, i))
        array.clear(profBoxes)
    if array.size(zoneBoxes) > 0
        for i = 0 to array.size(zoneBoxes) - 1
            box.delete(array.get(zoneBoxes, i))
        array.clear(zoneBoxes)
    if array.size(zoneLabels) > 0
        for i = 0 to array.size(zoneLabels) - 1
            label.delete(array.get(zoneLabels, i))
        array.clear(zoneLabels)

getStartIdx() =>
    int s = na
    if useVisible
        leftT = chart.left_visible_bar_time
        if not na(leftT)
            maxScan = math.min(5000, bar_index)
            for i = 0 to maxScan
                if time[i] <= leftT
                    s := bar_index - i
                    break
            if na(s)
                s := bar_index - maxScan
    if na(s)
        s := math.max(0, bar_index - lookback)
    s

// ─── Build & draw (last bar only) ───────────────────────────────────
if barstate.islast
    clearAll()

    startIdx = getStartIdx()
    nBars    = bar_index - startIdx + 1

    // 1. Range high / low
    float hi = -1e20
    float lo =  1e20
    for i = 0 to nBars - 1
        h = high[i]
        l = low[i]
        if not na(h) and h > hi
            hi := h
        if not na(l) and l < lo
            lo := l

    if hi > lo
        binSize = (hi - lo) / numBins
        vols    = array.new<float>(numBins, 0.0)

        // 2. Distribute each bar's volume across the bins it spans
        for i = 0 to nBars - 1
            bH = high[i]
            bL = low[i]
            bV = volume[i]
            if not (na(bH) or na(bL) or na(bV) or bV <= 0)
                rng = bH - bL
                if rng <= 0
                    bin = math.max(0, math.min(numBins - 1, math.floor((bH - lo) / binSize)))
                    array.set(vols, bin, array.get(vols, bin) + bV)
                else
                    sB  = math.max(0, math.floor((bL - lo) / binSize))
                    eB  = math.min(numBins - 1, math.floor((bH - lo) / binSize))
                    vpp = bV / rng
                    for b = sB to eB
                        bLo = lo + b * binSize
                        bHi = bLo + binSize
                        ov  = math.min(bH, bHi) - math.max(bL, bLo)
                        if ov > 0
                            array.set(vols, b, array.get(vols, b) + ov * vpp)

        // 3. Max volume for scaling
        float maxVol = 0.0
        for j = 0 to numBins - 1
            v = array.get(vols, j)
            if v > maxVol
                maxVol := v

        // 4. Draw profile histogram (anchored at current bar, extending right)
        profBarsWide = math.max(20, math.round(nBars * profileWidth / 100))
        profLeft     = bar_index

        if showProfile and maxVol > 0
            for bin = 0 to numBins - 1
                v = array.get(vols, bin)
                if v > 0
                    bLo = lo + bin * binSize
                    bHi = bLo + binSize
                    w   = math.min(math.max(1, math.round((v / maxVol) * profBarsWide)), 500)
                    pb  = box.new(profLeft, bHi, profLeft + w, bLo,
                         border_color=na, bgcolor=profileColor, xloc=xloc.bar_index)
                    array.push(profBoxes, pb)

        // 5. Detect cliffs and draw zones
        refPrice  = close
        zoneRight = bar_index + math.min(extendRight, 500)
        sigFloor  = maxVol * minSig / 100

        for bin = 0 to numBins - 2
            v1  = array.get(vols, bin)
            v2  = array.get(vols, bin + 1)
            big = math.max(v1, v2)

            // Skip insignificant pairs (e.g., both near zero at the edges)
            if big >= sigFloor and big > 0
                float ratio = 0.0
                bool  cliff = false

                if v1 > 0 and v2 > 0
                    ratio := big / math.min(v1, v2)
                    cliff := ratio >= cliffRatio
                else
                    cliff := true
                    ratio := 999.0

                if cliff
                    int eBin = bin + 1
                    int sBin = bin

                    if extendToLocal
                        // Determine high/low volume sides
                        bool highSideUp = v2 > v1
                        // Expand toward the local peak on the high-volume side
                        if highSideUp
                            bool peakWalk = true
                            while eBin < numBins - 1 and peakWalk
                                if array.get(vols, eBin + 1) > array.get(vols, eBin)
                                    eBin += 1
                                else
                                    peakWalk := false
                        else
                            bool peakWalk = true
                            while sBin > 0 and peakWalk
                                if array.get(vols, sBin - 1) > array.get(vols, sBin)
                                    sBin -= 1
                                else
                                    peakWalk := false
                        // Expand toward the local trough on the low-volume side
                        if highSideUp
                            bool troughWalk = true
                            while sBin > 0 and troughWalk
                                if array.get(vols, sBin - 1) < array.get(vols, sBin) and array.get(vols, sBin) > 0
                                    sBin -= 1
                                else
                                    troughWalk := false
                        else
                            bool troughWalk = true
                            while eBin < numBins - 1 and troughWalk
                                if array.get(vols, eBin + 1) < array.get(vols, eBin) and array.get(vols, eBin) > 0
                                    eBin += 1
                                else
                                    troughWalk := false

                    zTop = lo + (eBin + 1) * binSize
                    zBot = lo + sBin * binSize
                    zMid = (zTop + zBot) / 2
                    zCol = zMid > refPrice ? supplyColor : demandColor
                    brd  = showBorder ? color.new(zCol, 30) : color.new(zCol, 100)

                    zb = box.new(startIdx, zTop, zoneRight, zBot,
                         border_color=brd, border_width=1,
                         bgcolor=zCol, xloc=xloc.bar_index)
                    array.push(zoneBoxes, zb)

                    if showLabel
                        txt = ratio >= 999 ? "edge" : str.tostring(ratio, "#.#") + "x"
                        lb  = label.new(zoneRight, zMid, text=txt,
                             style=label.style_label_left,
                             color=color.new(zCol, 50),
                             textcolor=color.white,
                             size=size.small,
                             xloc=xloc.bar_index)
                        array.push(zoneLabels, lb)
