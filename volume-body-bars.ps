//@version=5
indicator("Volume Body Bars", overlay=true)

// ── Body Settings ──
minBodyRatio = input.float(0.75, "Min Body/Range Ratio", minval=0.0, maxval=1.0, step=0.05, group="Body")

// ── Volume Settings ──
volMode      = input.string("Previous Bars", "Volume Threshold Mode", options=["Previous Bars", "Moving Average"], group="Volume")
minVolRatio  = input.float(2.0, "Min Volume Ratio", minval=0.0, step=0.1, group="Volume")

// Previous Bars mode
prevBars     = input.int(1, "Previous Bars Count", minval=1, maxval=20, group="Volume — Previous Bars")

// Moving Average mode
maType       = input.string("SMA", "MA Type", options=["SMA", "EMA", "WMA", "SWMA", "DEMA", "TEMA", "HMA"], group="Volume — Moving Average")
maLength     = input.int(20, "MA Lookback", minval=1, group="Volume — Moving Average")

// ── MA Calculation ──
calcMA(src, len, typ) =>
    switch typ
        "SMA"  => ta.sma(src, len)
        "EMA"  => ta.ema(src, len)
        "WMA"  => ta.wma(src, len)
        "SWMA" => ta.swma(src)
        "DEMA" =>
            e1 = ta.ema(src, len)
            2 * e1 - ta.ema(e1, len)
        "TEMA" =>
            e1 = ta.ema(src, len)
            e2 = ta.ema(e1, len)
            3 * e1 - 3 * e2 + ta.ema(e2, len)
        "HMA" =>
            halfLen = math.max(math.round(len / 2), 1)
            sqrtLen = math.max(math.round(math.sqrt(len)), 1)
            ta.wma(2 * ta.wma(src, halfLen) - ta.wma(src, len), sqrtLen)

// ── Body Ratio ──
bodySize  = math.abs(close - open)
rangeSize = high - low
bodyRatio = rangeSize > 0 ? bodySize / rangeSize : 0.0

// ── Volume Ratio ──
float volRatio = 0.0

if volMode == "Previous Bars"
    float prevVolSum = 0.0
    for i = 1 to prevBars
        prevVolSum += volume[i]
    volRatio := prevVolSum > 0 ? volume / (prevVolSum / prevBars) : 0.0
else
    volMA = calcMA(volume, maLength, maType)
    volRatio := not na(volMA) and volMA > 0 ? volume / volMA : 0.0

// ── Signal ──
isQualified = bodyRatio >= minBodyRatio and volRatio >= minVolRatio
isBullish   = close >= open

plotshape(isQualified and isBullish, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small)
plotshape(isQualified and not isBullish, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small)
