indicator("Market Structure Trend Lines [SB]", "MSTL [SB]", overlay=true, max_lines_count=250, max_labels_count=250, max_boxes_count=500)

// Ensure sufficient historical buffer for lookback functions
max_bars_back(high, 5000)
max_bars_back(low, 5000)
max_bars_back(open, 5000)
max_bars_back(close, 5000)
max_bars_back(time, 5000)

// ============================================================================
// TIMEFRAME SETTINGS
// ============================================================================
tf1Timeframe = input.timeframe("", "Timeframe", group="Timeframe")

// ============================================================================
// STRUCTURE DISPLAY SETTINGS
