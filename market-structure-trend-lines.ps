showTf1PeaksValleys = input.bool(true, "Show Peaks/Valleys (Lines)", group="Structure Display")
showTf1Labels = input.bool(false, "Show Level Labels", group="Structure Display")
showTf1BosLabels = input.bool(true, "Show BOS Labels", group="Structure Display")
showTf1Zones = input.bool(true, "Show Zones", group="Structure Display")
tf1ZonesUseFullSwings = input.bool(false, "Zones: Use Full Swings", group="Structure Display")

// ============================================================================
// COLORS
// ============================================================================
highColor = input.color(color.new(color.red, 0), "High Color", group="Colors")
lowColor = input.color(color.new(color.green, 0), "Low Color", group="Colors")
bosColor = input.color(color.new(color.black, 0), "BOS Color", group="Colors")
tf1DemandZoneColor = input.color(color.new(color.green, 85), "Demand Zone Color", group="Colors")
tf1DemandZoneBorderColor = input.color(color.new(color.green, 50), "Demand Zone Border", group="Colors")
tf1SupplyZoneColor = input.color(color.new(color.red, 85), "Supply Zone Color", group="Colors")
tf1SupplyZoneBorderColor = input.color(color.new(color.red, 50), "Supply Zone Border", group="Colors")

// ============================================================================
// ZONE SETTINGS
// ============================================================================
showBrokenTf1Zones = input.bool(false, "Show Broken Zones", group="Zone Settings")
extendBrokenZones = input.bool(false, "Extend Broken Zones to Current Bar", group="Zone Settings")
maxZonesPerSide = input.int(20, "Max Zones Per Side", minval=10, maxval=250, group="Zone Settings")
zoneBreakOnWick = input.bool(false, "Break Zones on Wick (not just close)", group="Zone Settings")
zoneBreakOnFirstTouch = input.bool(false, "Break Zones on First Touch", group="Zone Settings")
zoneBreakOnTouchAfterCreation = input.bool(false, "Break Zones on Touch After Creation", group="Zone Settings")

// ============================================================================
// DISPLAY SETTINGS
// ============================================================================
lineWidth = input.int(2, "Line Width", minval=1, maxval=5, group="Display")

// ============================================================================
// TREND LINE SETTINGS
// ============================================================================
showTrendLines = input.bool(true, "Show Trend Lines", group="Trend Lines")
minPoints = input.int(3, "Min Points for Fit", minval=2, maxval=10, group="Trend Lines")
maxLookbackPoints = input.int(10, "Max Lookback Points", minval=3, maxval=30, group="Trend Lines")
r2Threshold = input.float(0.80, "R² Threshold", minval=0.0, maxval=1.0, step=0.05, group="Trend Lines")
resistanceColor = input.color(color.new(color.red, 0), "Resistance Line Color", group="Trend Lines")
supportColor = input.color(color.new(color.green, 0), "Support Line Color", group="Trend Lines")
trendLineWidth = input.int(2, "Trend Line Width", minval=1, maxval=5, group="Trend Lines")
showR2Labels = input.bool(false, "Show R² Labels", group="Trend Lines")
maxHistoricalLines = input.int(5, "Max Historical Lines", minval=0, maxval=20, group="Trend Lines")

// TF1 display string for labels
string tf1DisplayTF = tf1Timeframe == "" ? timeframe.period : tf1Timeframe

// ============================================================================
// TYPE DEFINITIONS
// ============================================================================

type HighLevel
    float price
    int barIndex
    line levelLine
    string levelType  // "strong", "weak", "broken", "swept"
    bool zoneCreated

type LowLevel
    float price
    int barIndex
    line levelLine
    string levelType  // "strong", "weak", "broken", "swept"
    bool zoneCreated

type Zone
    float top
    float bottom
    int leftTime
    int rightTime
    bool broken
    bool touched
    int creationBar

type TrendLine
    float slope
    float intercept
    float r2
    int pointCount
    int startBar
    int endBar
    line lineObj
    label r2Label
    bool broken
    bool isSupport  // true = through lows, false = through highs

// ============================================================================
// STATE VARIABLES
// ============================================================================

// Structure arrays
var array<HighLevel> highs = array.new<HighLevel>()
var array<LowLevel> lows = array.new<LowLevel>()

// Zones
var array<Zone> tf1DemandZones = array.new<Zone>()
var array<Zone> tf1SupplyZones = array.new<Zone>()

// Market structure state
var float currentValidHigh = na
var float currentValidLow = na
var int currentValidHighBar = na
var int currentValidLowBar = na
var bool initialized = false
var bool lookingForLow = false
var bool lookingForHigh = false
var bool currentHighIsBroken = false
var bool currentLowIsBroken = false
var string lastBosDirection = "none"

var int mostRecentHighIndex = -1
var int mostRecentLowIndex = -1

var float previousValidHigh = na
var float previousValidLow = na
var int previousValidHighBar = na
var int previousValidLowBar = na

var int nearestUnbrokenHighIndex = -1
var int nearestUnbrokenLowIndex = -1
var line nearestUnbrokenHighLine = na
var line nearestUnbrokenLowLine = na

// Labels
var label currentHighLabel = na
var label currentLowLabel = na
var label nearestUnbrokenHighLabel = na
var label nearestUnbrokenLowLabel = na

// Trend line state
var TrendLine activeSupportLine = na
var TrendLine activeResistanceLine = na
var array<TrendLine> historicalLines = array.new<TrendLine>()
var bool needSupportFit = false
var bool needResistanceFit = false

// ============================================================================
// TF1 DATA
// ============================================================================

[tf1High, tf1Low, tf1Open, tf1Close] = request.security(syminfo.tickerid, tf1Timeframe, [high, low, open, close], lookahead=barmerge.lookahead_off)
tf1Time = request.security(syminfo.tickerid, tf1Timeframe, time, lookahead=barmerge.lookahead_off)
bool tf1NewCandle = ta.change(tf1Time) != 0

// ============================================================================
// HELPER FUNCTIONS
// ============================================================================

isBearishBreakdown() =>
    tf1Close < tf1Open and tf1Close < tf1Low[1]

isBullishBreakout() =>
    tf1Close > tf1Open and tf1Close > tf1High[1]

findLowestBetween(startBar, endBar) =>
    float lowestPrice = na
    int lowestBarIndex = na

    int start = startBar
    int end = endBar

    if start > end
        int temp = start
        start := end
        end := temp

    int currentBar = bar_index
    int lookbackStart = currentBar - end
    int lookbackEnd = currentBar - start - 1

    int maxLookback = 5000
    lookbackStart := math.max(lookbackStart, 0)
    lookbackEnd := math.min(lookbackEnd, maxLookback)

    if lookbackStart <= lookbackEnd and lookbackEnd >= 0 and lookbackStart <= maxLookback
        for i = lookbackStart to lookbackEnd
            if i >= 0 and not na(low[i])
                if na(lowestPrice) or low[i] < lowestPrice
                    lowestPrice := low[i]
                    lowestBarIndex := currentBar - i

    [lowestPrice, lowestBarIndex]

findHighestBetween(startBar, endBar) =>
    float highestPrice = na
    int highestBarIndex = na

    int start = startBar
    int end = endBar

    if start > end
        int temp = start
        start := end
        end := temp

    int currentBar = bar_index
    int lookbackStart = currentBar - end
    int lookbackEnd = currentBar - start - 1

    int maxLookback = 5000
    lookbackStart := math.max(lookbackStart, 0)
    lookbackEnd := math.min(lookbackEnd, maxLookback)

    if lookbackStart <= lookbackEnd and lookbackEnd >= 0 and lookbackStart <= maxLookback
        for i = lookbackStart to lookbackEnd
            if i >= 0 and not na(high[i])
                if na(highestPrice) or high[i] > highestPrice
                    highestPrice := high[i]
                    highestBarIndex := currentBar - i

    [highestPrice, highestBarIndex]

// ============================================================================
// LINEAR REGRESSION
// ============================================================================

// Perform linear regression on arrays of x (bar indices) and y (prices)
// Returns [slope, intercept, r2]
linearRegression(array<float> xArr, array<float> yArr, int n) =>
    float slope = 0.0
    float intercept = 0.0
    float r2 = 0.0

    if n >= 2
        float sumX = 0.0
        float sumY = 0.0
        float sumXY = 0.0
        float sumX2 = 0.0
        float sumY2 = 0.0

        for i = 0 to n - 1
            float x = array.get(xArr, i)
            float y = array.get(yArr, i)
            sumX += x
            sumY += y
            sumXY += x * y
            sumX2 += x * x
            sumY2 += y * y

        float denom = n * sumX2 - sumX * sumX

        if math.abs(denom) < 1e-10
            // All x identical (degenerate)
            slope := 0.0
            intercept := sumY / n
            r2 := 0.0
        else
            slope := (n * sumXY - sumX * sumY) / denom
            intercept := (sumY - slope * sumX) / n

            // R² calculation
            float meanY = sumY / n
            float ssTot = 0.0
            float ssRes = 0.0
            for i = 0 to n - 1
                float y = array.get(yArr, i)
                float x = array.get(xArr, i)
                float predicted = slope * x + intercept
                ssTot += (y - meanY) * (y - meanY)
                ssRes += (y - predicted) * (y - predicted)

            if math.abs(ssTot) < 1e-10
                // All y identical -> perfect horizontal line
                r2 := 1.0
            else
                r2 := 1.0 - ssRes / ssTot
                r2 := math.max(0.0, r2)

    [slope, intercept, r2]

// Fit a trend line through structure points with iterative outlier removal
// isSupport: true = fit through lows, false = fit through highs
// Returns [slope, intercept, r2, pointCount, startBar, endBar, valid]
fitTrendLine(bool isSupport) =>
    float bestSlope = 0.0
    float bestIntercept = 0.0
    float bestR2 = 0.0
    int bestCount = 0
    int bestStartBar = 0
    int bestEndBar = 0
    bool valid = false

    // Collect points from structure arrays
    var array<float> xPoints = array.new<float>()
    var array<float> yPoints = array.new<float>()
    array.clear(xPoints)
    array.clear(yPoints)

    if isSupport
        int sz = array.size(lows)
        int startIdx = math.max(0, sz - maxLookbackPoints)
        for i = startIdx to sz - 1
            lowLevel = array.get(lows, i)
            array.push(xPoints, float(lowLevel.barIndex))
            array.push(yPoints, lowLevel.price)
    else
        int sz = array.size(highs)
        int startIdx = math.max(0, sz - maxLookbackPoints)
        for i = startIdx to sz - 1
            highLevel = array.get(highs, i)
            array.push(xPoints, float(highLevel.barIndex))
            array.push(yPoints, highLevel.price)

    int n = array.size(xPoints)

    if n >= minPoints
        // Iterative outlier removal
        int maxIter = n - minPoints
        int iter = 0
        bool done = false

        while not done and iter <= maxIter
            int currentN = array.size(xPoints)
            if currentN < minPoints
                done := true
            else
                [s, ic, r] = linearRegression(xPoints, yPoints, currentN)
                if r >= r2Threshold
                    bestSlope := s
                    bestIntercept := ic
                    bestR2 := r
                    bestCount := currentN
                    bestStartBar := math.round(array.get(xPoints, 0))
                    bestEndBar := math.round(array.get(xPoints, currentN - 1))
                    valid := true
                    done := true
                else if currentN <= minPoints
                    // At minimum points and still below threshold -> no valid line
                    done := true
                else
                    // Remove worst outlier
                    float maxResidual = 0.0
                    int worstIdx = -1
                    for i = 0 to currentN - 1
                        float x = array.get(xPoints, i)
                        float y = array.get(yPoints, i)
                        float predicted = s * x + ic
                        float residual = math.abs(y - predicted)
                        if residual > maxResidual
                            maxResidual := residual
                            worstIdx := i
                    if worstIdx >= 0
                        array.remove(xPoints, worstIdx)
                        array.remove(yPoints, worstIdx)
                    else
                        done := true
                iter += 1

    [bestSlope, bestIntercept, bestR2, bestCount, bestStartBar, bestEndBar, valid]

// ============================================================================
// LEVEL MANAGEMENT FUNCTIONS
// ============================================================================

addHigh(float price, int barIdx, string levelType, color lineColor) =>
    if mostRecentHighIndex >= 0
        prevHigh = array.get(highs, mostRecentHighIndex)
        if prevHigh.levelType != "broken" and prevHigh.levelType != "swept" and not na(prevHigh.levelLine)
            line.delete(prevHigh.levelLine)

    line newLine = na
    if showTf1PeaksValleys
        newLine := line.new(barIdx, price, barIdx + 1, price,
                           color=lineColor,
                           width=lineWidth,
                           extend=extend.right,
                           style=line.style_solid)

    newHigh = HighLevel.new(price, barIdx, newLine, levelType, false)
    array.push(highs, newHigh)

    if showTf1Labels
        label.new(barIdx, price, "",
                 style=label.style_label_down,
                 color=lineColor,
                 textcolor=color.white,
                 size=size.tiny)

    true

addLow(float price, int barIdx, string levelType, color lineColor) =>
    if mostRecentLowIndex >= 0
        prevLow = array.get(lows, mostRecentLowIndex)
        if prevLow.levelType != "broken" and prevLow.levelType != "swept" and not na(prevLow.levelLine)
            line.delete(prevLow.levelLine)

    line newLine = na
    if showTf1PeaksValleys
        newLine := line.new(barIdx, price, barIdx + 1, price,
                           color=lineColor,
                           width=lineWidth,
                           extend=extend.right,
                           style=line.style_solid)

    newLow = LowLevel.new(price, barIdx, newLine, levelType, false)
    array.push(lows, newLow)

    if showTf1Labels
        label.new(barIdx, price, "",
                 style=label.style_label_up,
                 color=lineColor,
                 textcolor=color.white,
                 size=size.tiny)

    true

getHighLevelType(string bosDirection) =>
    bosDirection == "bullish" ? "weak" : "strong"

getLowLevelType(string bosDirection) =>
    bosDirection == "bearish" ? "weak" : "strong"

// ============================================================================
// ZONE MANAGEMENT FUNCTIONS
// ============================================================================

checkDemandZone(Zone zone) =>
    if not zone.broken
        bool isTouching = low <= zone.top and high >= zone.bottom
        if isTouching and not zone.touched
            zone.touched := true
        bool shouldBreak = close < zone.bottom or (zoneBreakOnWick and low < zone.bottom) or ((zoneBreakOnFirstTouch or zoneBreakOnTouchAfterCreation) and isTouching and bar_index > zone.creationBar)
        if shouldBreak
            zone.broken := true
            zone.rightTime := time
    true

checkSupplyZone(Zone zone) =>
    if not zone.broken
        bool isTouching = low <= zone.top and high >= zone.bottom
        if isTouching and not zone.touched
            zone.touched := true
        bool shouldBreak = close > zone.top or (zoneBreakOnWick and high > zone.top) or ((zoneBreakOnFirstTouch or zoneBreakOnTouchAfterCreation) and isTouching and bar_index > zone.creationBar)
        if shouldBreak
            zone.broken := true
            zone.rightTime := time
    true

checkAllBrokenZones() =>
    for i = 0 to math.max(0, array.size(tf1DemandZones) - 1)
        if i < array.size(tf1DemandZones)
            checkDemandZone(array.get(tf1DemandZones, i))
    for i = 0 to math.max(0, array.size(tf1SupplyZones) - 1)
        if i < array.size(tf1SupplyZones)
            checkSupplyZone(array.get(tf1SupplyZones, i))
    true

// ============================================================================
// CHECK FOR BROKEN AND SWEPT LEVELS
// ============================================================================

checkBrokenLevels(float tfHigh, float tfLow, float tfClose) =>
    bool bullishBos = false
    bool bearishBos = false

    if array.size(highs) > 0
        for i = array.size(highs) - 1 to 0
            highLevel = array.get(highs, i)

            if highLevel.levelType != "swept" and highLevel.levelType != "broken" and tfHigh > highLevel.price and tfClose <= highLevel.price
                highLevel.levelType := "swept"
                if not na(highLevel.levelLine)
                    line.set_style(highLevel.levelLine, line.style_dashed)
                array.set(highs, i, highLevel)

            else if highLevel.levelType != "broken" and tfClose > highLevel.price
                highLevel.levelType := "broken"

                if i == mostRecentHighIndex
                    if showTf1Zones
                        int barsBack = bar_index - highLevel.barIndex
                        if barsBack >= 0 and barsBack < 5000
                            float zoneBottom = low
                            int zoneBottomIdx = 0
                            for j = 0 to math.min(barsBack, 5000)
                                if low[j] < zoneBottom
                                    zoneBottom := low[j]
                                    zoneBottomIdx := j

                            float zoneTop = na
                            int zoneLeftIdx = zoneBottomIdx

                            if tf1ZonesUseFullSwings
                                zoneTop := highLevel.price
                                zoneLeftIdx := barsBack
                            else
                                bool foundBearish = false
                                float highestBearishHigh = na
                                int maxWalk = math.min(zoneBottomIdx + 50, 5000)

                                for j = zoneBottomIdx to maxWalk
                                    bool isBearish = close[j] < open[j]
                                    bool isBullish = close[j] > open[j]

                                    if not foundBearish
                                        if isBearish
                                            foundBearish := true
                                            highestBearishHigh := high[j]
                                            zoneLeftIdx := j
                                    else
                                        if isBullish
                                            break
                                        else if isBearish
                                            if high[j] > highestBearishHigh
                                                highestBearishHigh := high[j]
                                            zoneLeftIdx := j

                                zoneTop := foundBearish ? highestBearishHigh : highLevel.price

                            int zoneLeftTime = time[zoneLeftIdx]
                            if not na(zoneTop) and zoneTop > zoneBottom
                                newZone = Zone.new(zoneTop, zoneBottom, zoneLeftTime, time, false, false, bar_index)
                                array.push(tf1DemandZones, newZone)

                array.set(highs, i, highLevel)

                if i == mostRecentHighIndex
                    if not na(highLevel.levelLine)
                        line.set_x2(highLevel.levelLine, bar_index)
                        line.set_extend(highLevel.levelLine, extend.none)
                        line.set_style(highLevel.levelLine, line.style_dotted)
                        line.set_color(highLevel.levelLine, color.new(bosColor, 30))

                    bullishBos := true

                    if showTf1BosLabels
                        centerBar = math.round((highLevel.barIndex + bar_index) / 2)
                        label.new(centerBar, highLevel.price, "BOS↑",
                                 style=label.style_label_center,
                                 color=color.white,
                                 textcolor=bosColor,
                                 size=size.tiny)
                else
                    if not na(highLevel.levelLine)
                        line.delete(highLevel.levelLine)

    if array.size(lows) > 0
        for i = array.size(lows) - 1 to 0
            lowLevel = array.get(lows, i)

            if lowLevel.levelType != "swept" and lowLevel.levelType != "broken" and tfLow < lowLevel.price and tfClose >= lowLevel.price
                lowLevel.levelType := "swept"
                if not na(lowLevel.levelLine)
                    line.set_style(lowLevel.levelLine, line.style_dashed)
                array.set(lows, i, lowLevel)

            else if lowLevel.levelType != "broken" and tfClose < lowLevel.price
                lowLevel.levelType := "broken"

                if i == mostRecentLowIndex
                    if showTf1Zones
                        int barsBack = bar_index - lowLevel.barIndex
                        if barsBack >= 0 and barsBack < 5000
                            float zoneTop = high
                            int zoneTopIdx = 0
                            for j = 0 to math.min(barsBack, 5000)
                                if high[j] > zoneTop
                                    zoneTop := high[j]
                                    zoneTopIdx := j

                            float zoneBottom = na
                            int zoneLeftIdx = zoneTopIdx

                            if tf1ZonesUseFullSwings
                                zoneBottom := lowLevel.price
                                zoneLeftIdx := barsBack
                            else
                                bool foundBullish = false
                                float lowestBullishLow = na
                                int maxWalk = math.min(zoneTopIdx + 50, 5000)

                                for j = zoneTopIdx to maxWalk
                                    bool isBearish = close[j] < open[j]
                                    bool isBullish = close[j] > open[j]

                                    if not foundBullish
                                        if isBullish
                                            foundBullish := true
                                            lowestBullishLow := low[j]
                                            zoneLeftIdx := j
                                    else
                                        if isBearish
                                            break
                                        else if isBullish
                                            if low[j] < lowestBullishLow
                                                lowestBullishLow := low[j]
                                            zoneLeftIdx := j

                                zoneBottom := foundBullish ? lowestBullishLow : lowLevel.price

                            int zoneLeftTime = time[zoneLeftIdx]
                            if not na(zoneBottom) and zoneTop > zoneBottom
                                newZone = Zone.new(zoneTop, zoneBottom, zoneLeftTime, time, false, false, bar_index)
                                array.push(tf1SupplyZones, newZone)

                array.set(lows, i, lowLevel)

                if i == mostRecentLowIndex
                    if not na(lowLevel.levelLine)
                        line.set_x2(lowLevel.levelLine, bar_index)
                        line.set_extend(lowLevel.levelLine, extend.none)
                        line.set_style(lowLevel.levelLine, line.style_dotted)
                        line.set_color(lowLevel.levelLine, color.new(bosColor, 30))

                    bearishBos := true

                    if showTf1BosLabels
                        centerBar = math.round((lowLevel.barIndex + bar_index) / 2)
                        label.new(centerBar, lowLevel.price, "BOS↓",
                                 style=label.style_label_center,
                                 color=color.white,
                                 textcolor=bosColor,
                                 size=size.tiny)
                else
                    if not na(lowLevel.levelLine)
                        line.delete(lowLevel.levelLine)

    [bullishBos, bearishBos]

// ============================================================================
// NEAREST UNBROKEN LEVEL FUNCTIONS
// ============================================================================

findNearestUnbrokenHigh(array<HighLevel> highsArray) =>
    int result = -1
    if array.size(highsArray) > 0
        for i = array.size(highsArray) - 1 to 0
            highLevel = array.get(highsArray, i)
            if highLevel.levelType != "broken"
                result := i
                break
    result

findNearestUnbrokenLow(array<LowLevel> lowsArray) =>
    int result = -1
    if array.size(lowsArray) > 0
        for i = array.size(lowsArray) - 1 to 0
            lowLevel = array.get(lowsArray, i)
            if lowLevel.levelType != "broken"
                result := i
                break
    result

// ============================================================================
// TREND LINE FUNCTIONS
// ============================================================================

// Move active trend line to historical, applying dashed style
retireTrendLine(TrendLine tl) =>
    if not na(tl)
        tl.broken := true
        if not na(tl.lineObj)
            line.set_style(tl.lineObj, line.style_dashed)
            line.set_extend(tl.lineObj, extend.none)
            // Set x2 to current bar
            float projectedY = tl.slope * bar_index + tl.intercept
            line.set_x2(tl.lineObj, bar_index)
            line.set_y2(tl.lineObj, projectedY)
        if not na(tl.r2Label)
            label.delete(tl.r2Label)
            tl.r2Label := na
        array.push(historicalLines, tl)
        // Trim historical lines
        while array.size(historicalLines) > maxHistoricalLines
            oldest = array.shift(historicalLines)
            if not na(oldest.lineObj)
                line.delete(oldest.lineObj)
            if not na(oldest.r2Label)
                label.delete(oldest.r2Label)
    true

// Update or create a trend line for support or resistance
// Takes the current active line (to retire if replaced), returns the new active line
updateTrendLine(bool isSupport, TrendLine oldLine) =>
    [slope, intercept, r2, pointCount, startBar, endBar, valid] = fitTrendLine(isSupport)

    TrendLine result = oldLine

    if valid
        // Check if line is already broken at current bar
        float projectedNow = slope * bar_index + intercept
        bool alreadyBroken = isSupport ? (close < projectedNow) : (close > projectedNow)

        if not alreadyBroken
            // Retire the current active line
            if not na(oldLine)
                retireTrendLine(oldLine)

            // Create visual line
            float y1 = slope * startBar + intercept
            float y2 = slope * endBar + intercept
            color lineCol = isSupport ? supportColor : resistanceColor
            line newLine = line.new(startBar, y1, endBar, y2,
                                   color=lineCol,
                                   width=trendLineWidth,
                                   style=line.style_solid,
                                   extend=extend.right)

            // Create R² label if enabled
            label r2Lbl = na
            if showR2Labels
                r2Lbl := label.new(endBar, y2, "R²=" + str.tostring(r2, "#.##"),
                                  style=isSupport ? label.style_label_up : label.style_label_down,
                                  color=lineCol,
                                  textcolor=color.white,
                                  size=size.tiny)

            result := TrendLine.new(slope, intercept, r2, pointCount, startBar, endBar, newLine, r2Lbl, false, isSupport)

    result

// Check if active trend lines have been broken by price
// Returns [supportBroken, resistanceBroken]
checkTrendLineBreaks(TrendLine supportLine, TrendLine resistanceLine) =>
    bool supportBroken = false
    bool resistanceBroken = false

    // Check support line
    if not na(supportLine)
        if not supportLine.broken
            float projected = supportLine.slope * bar_index + supportLine.intercept
            if close < projected
                retireTrendLine(supportLine)
                supportBroken := true

    // Check resistance line
    if not na(resistanceLine)
        if not resistanceLine.broken
            float projected = resistanceLine.slope * bar_index + resistanceLine.intercept
            if close > projected
                retireTrendLine(resistanceLine)
                resistanceBroken := true

    [supportBroken, resistanceBroken]

// Extend active trend lines visually to current bar
extendActiveTrendLines() =>
    if not na(activeSupportLine)
        if not activeSupportLine.broken and not na(activeSupportLine.lineObj)
            float y2 = activeSupportLine.slope * bar_index + activeSupportLine.intercept
            line.set_x2(activeSupportLine.lineObj, bar_index)
            line.set_y2(activeSupportLine.lineObj, y2)
            if showR2Labels and not na(activeSupportLine.r2Label)
                label.set_x(activeSupportLine.r2Label, bar_index)
                label.set_y(activeSupportLine.r2Label, y2)

    if not na(activeResistanceLine)
        if not activeResistanceLine.broken and not na(activeResistanceLine.lineObj)
            float y2 = activeResistanceLine.slope * bar_index + activeResistanceLine.intercept
            line.set_x2(activeResistanceLine.lineObj, bar_index)
            line.set_y2(activeResistanceLine.lineObj, y2)
            if showR2Labels and not na(activeResistanceLine.r2Label)
                label.set_x(activeResistanceLine.r2Label, bar_index)
                label.set_y(activeResistanceLine.r2Label, y2)
    true

// ============================================================================
// INITIALIZATION
// ============================================================================

if not initialized and bar_index > 0 and tf1NewCandle
    if isBearishBreakdown()
        float localHigh = high
        int localHighBar = bar_index

        for i = 1 to math.min(bar_index, 5000)
            if high[i] > localHigh
                localHigh := high[i]
                localHighBar := bar_index - i

        currentValidHigh := localHigh
        currentValidHighBar := localHighBar
        initialized := true
        lookingForLow := true

        addHigh(localHigh, localHighBar, "strong", highColor)
        mostRecentHighIndex := array.size(highs) - 1
        needResistanceFit := true

// ============================================================================
// MAIN LOGIC (gated on tf1NewCandle)
// ============================================================================

if initialized and tf1NewCandle
    [tf1BullBos, tf1BearBos] = checkBrokenLevels(tf1High, tf1Low, tf1Close)

    bool bosBullish = false
    bool bosBearish = false

    // Check for Break of Structure
    if not na(currentValidHigh) and not na(currentValidLow) and tf1Close > currentValidHigh and lookingForLow
        bosBullish := true
        currentHighIsBroken := true
        lastBosDirection := "bullish"

        [newLow, newLowBar] = findLowestBetween(currentValidHighBar, bar_index)

        if not na(newLow) and not na(newLowBar)
            previousValidLow := currentValidLow
            previousValidLowBar := currentValidLowBar

            currentValidLow := newLow
            currentValidLowBar := newLowBar
            lookingForHigh := true
            lookingForLow := false
            currentLowIsBroken := false

            addLow(newLow, newLowBar, "strong", lowColor)
            mostRecentLowIndex := array.size(lows) - 1
            needSupportFit := true

    if not bosBullish and not na(currentValidLow) and not na(currentValidHigh) and tf1Close < currentValidLow and lookingForHigh
        bosBearish := true
        currentLowIsBroken := true
        lastBosDirection := "bearish"

        [newHigh, newHighBar] = findHighestBetween(currentValidLowBar, bar_index)

        if not na(newHigh) and not na(newHighBar)
            previousValidHigh := currentValidHigh
            previousValidHighBar := currentValidHighBar

            currentValidHigh := newHigh
            currentValidHighBar := newHighBar
            lookingForLow := true
            lookingForHigh := false
            currentHighIsBroken := false

            addHigh(newHigh, newHighBar, "strong", highColor)
            mostRecentHighIndex := array.size(highs) - 1
            needResistanceFit := true

    // Look for new valid low via breakout
    if not bosBullish and not bosBearish and lookingForLow
        if isBullishBreakout()
            [newLow, newLowBar] = findLowestBetween(currentValidHighBar, bar_index)

            if not na(newLow) and not na(newLowBar)
                currentValidLow := newLow
                currentValidLowBar := newLowBar
                lookingForHigh := true
                lookingForLow := false
                currentLowIsBroken := false

                levelType = getLowLevelType(lastBosDirection)
                addLow(newLow, newLowBar, levelType, lowColor)
                mostRecentLowIndex := array.size(lows) - 1
                needSupportFit := true

    // Look for new valid high via breakdown
    if not bosBullish and not bosBearish and lookingForHigh
        if isBearishBreakdown()
            [newHigh, newHighBar] = findHighestBetween(currentValidLowBar, bar_index)

            if not na(newHigh) and not na(newHighBar)
                currentValidHigh := newHigh
                currentValidHighBar := newHighBar
                lookingForLow := true
                lookingForHigh := false
                currentHighIsBroken := false

                levelType = getHighLevelType(lastBosDirection)
                addHigh(newHigh, newHighBar, levelType, highColor)
                mostRecentHighIndex := array.size(highs) - 1
                needResistanceFit := true

// ============================================================================
// MAIN LOGIC (ungated, every bar)
// ============================================================================

if initialized
    checkAllBrokenZones()

    // Update nearest unbroken levels
    int tf1NewHighIdx = findNearestUnbrokenHigh(highs)
    if tf1NewHighIdx != nearestUnbrokenHighIndex or (tf1NewHighIdx >= 0 and na(nearestUnbrokenHighLine))
        if not na(nearestUnbrokenHighLine)
            line.delete(nearestUnbrokenHighLine)
            nearestUnbrokenHighLine := na
        nearestUnbrokenHighIndex := tf1NewHighIdx
        if tf1NewHighIdx >= 0 and tf1NewHighIdx != mostRecentHighIndex
            tf1HighLevel = array.get(highs, tf1NewHighIdx)
            nearestUnbrokenHighLine := line.new(bar_index, tf1HighLevel.price, bar_index + 1, tf1HighLevel.price, color=color.new(highColor, 50), width=lineWidth, extend=extend.right, style=line.style_dashed)
    if not na(nearestUnbrokenHighLine)
        line.set_x2(nearestUnbrokenHighLine, bar_index + 1)

    int tf1NewLowIdx = findNearestUnbrokenLow(lows)
    if tf1NewLowIdx != nearestUnbrokenLowIndex or (tf1NewLowIdx >= 0 and na(nearestUnbrokenLowLine))
        if not na(nearestUnbrokenLowLine)
            line.delete(nearestUnbrokenLowLine)
            nearestUnbrokenLowLine := na
        nearestUnbrokenLowIndex := tf1NewLowIdx
        if tf1NewLowIdx >= 0 and tf1NewLowIdx != mostRecentLowIndex
            tf1LowLevel = array.get(lows, tf1NewLowIdx)
            nearestUnbrokenLowLine := line.new(bar_index, tf1LowLevel.price, bar_index + 1, tf1LowLevel.price, color=color.new(lowColor, 50), width=lineWidth, extend=extend.right, style=line.style_dashed)
    if not na(nearestUnbrokenLowLine)
        line.set_x2(nearestUnbrokenLowLine, bar_index + 1)

    // Trend line logic
    if showTrendLines
        // Check for breaks first (every bar)
        [supportBroken, resistanceBroken] = checkTrendLineBreaks(activeSupportLine, activeResistanceLine)
        if supportBroken
            activeSupportLine := na
            needSupportFit := true
        if resistanceBroken
            activeResistanceLine := na
            needResistanceFit := true

        // Re-fit trend lines when triggered
        if needResistanceFit
            activeResistanceLine := updateTrendLine(false, activeResistanceLine)
            needResistanceFit := false
        if needSupportFit
            activeSupportLine := updateTrendLine(true, activeSupportLine)
            needSupportFit := false

        // Extend active lines
        extendActiveTrendLines()

// ============================================================================
// UPDATE LEVEL STATES
// ============================================================================

if initialized
    int brokenHighIdx = -1
    if array.size(highs) > 0
        for i = array.size(highs) - 1 to 0
            highLevel = array.get(highs, i)
            if highLevel.levelType == "broken"
                brokenHighIdx := i
                break

    int brokenLowIdx = -1
    if array.size(lows) > 0
        for i = array.size(lows) - 1 to 0
            lowLevel = array.get(lows, i)
            if lowLevel.levelType == "broken"
                brokenLowIdx := i
                break

    if brokenHighIdx >= 0 or brokenLowIdx >= 0
        if brokenHighIdx >= 0 and (brokenLowIdx < 0 or brokenHighIdx > brokenLowIdx)
            lastBosDirection := "bullish"

            if mostRecentHighIndex >= 0
                currentHigh = array.get(highs, mostRecentHighIndex)
                if currentHigh.levelType != "broken" and currentHigh.levelType != "swept"
                    currentHigh.levelType := "weak"

            if mostRecentLowIndex >= 0
                currentLow = array.get(lows, mostRecentLowIndex)
                if currentLow.levelType != "broken" and currentLow.levelType != "swept"
                    currentLow.levelType := "strong"

        else if brokenLowIdx >= 0
            lastBosDirection := "bearish"

            if mostRecentLowIndex >= 0
                currentLow = array.get(lows, mostRecentLowIndex)
                if currentLow.levelType != "broken" and currentLow.levelType != "swept"
                    currentLow.levelType := "weak"

            if mostRecentHighIndex >= 0
                currentHigh = array.get(highs, mostRecentHighIndex)
                if currentHigh.levelType != "broken" and currentHigh.levelType != "swept"
                    currentHigh.levelType := "strong"

// ============================================================================
// ARRAY TRUNCATION
// ============================================================================

if array.size(highs) > 30
    oldHigh = array.get(highs, 0)
    if not na(oldHigh.levelLine)
        line.delete(oldHigh.levelLine)
    array.shift(highs)
    mostRecentHighIndex := math.max(-1, mostRecentHighIndex - 1)
    nearestUnbrokenHighIndex := math.max(-1, nearestUnbrokenHighIndex - 1)
    if nearestUnbrokenHighIndex < 0 and not na(nearestUnbrokenHighLine)
        line.delete(nearestUnbrokenHighLine)
        nearestUnbrokenHighLine := na

if array.size(lows) > 30
    oldLow = array.get(lows, 0)
    if not na(oldLow.levelLine)
        line.delete(oldLow.levelLine)
    array.shift(lows)
    mostRecentLowIndex := math.max(-1, mostRecentLowIndex - 1)
    nearestUnbrokenLowIndex := math.max(-1, nearestUnbrokenLowIndex - 1)
    if nearestUnbrokenLowIndex < 0 and not na(nearestUnbrokenLowLine)
        line.delete(nearestUnbrokenLowLine)
        nearestUnbrokenLowLine := na

// ============================================================================
// PLOTS AND LABELS
// ============================================================================

plot(currentValidHigh, "Current Valid High", color=color.new(highColor, 80), linewidth=1, style=plot.style_stepline)
plot(currentValidLow, "Current Valid Low", color=color.new(lowColor, 80), linewidth=1, style=plot.style_stepline)

// Update labels for current levels
if initialized and not na(currentValidHigh) and mostRecentHighIndex >= 0
    if not na(currentHighLabel)
        label.delete(currentHighLabel)

    highLevel = array.get(highs, mostRecentHighIndex)
    string labelText = na
    color labelColor = highColor

    if highLevel.levelType == "broken"
        labelText := tf1DisplayTF + " Broken High"
        labelColor := color.new(color.red, 0)
    else if highLevel.levelType == "weak"
        labelText := tf1DisplayTF + " Weak High"
    else if highLevel.levelType == "swept"
        labelText := tf1DisplayTF + " Swept High"
    else
        labelText := tf1DisplayTF + " Strong High"

    currentHighLabel := label.new(bar_index + 5, currentValidHigh,
                                   text=labelText,
                                   style=label.style_label_left,
                                   color=labelColor,
                                   textcolor=color.white,
                                   size=size.small)

if initialized and not na(currentValidLow) and mostRecentLowIndex >= 0
    if not na(currentLowLabel)
        label.delete(currentLowLabel)

    lowLevel = array.get(lows, mostRecentLowIndex)
    string labelText = na
    color labelColor = lowColor

    if lowLevel.levelType == "broken"
        labelText := tf1DisplayTF + " Broken Low"
        labelColor := color.new(color.green, 0)
    else if lowLevel.levelType == "weak"
        labelText := tf1DisplayTF + " Weak Low"
    else if lowLevel.levelType == "swept"
        labelText := tf1DisplayTF + " Swept Low"
    else
        labelText := tf1DisplayTF + " Strong Low"

    currentLowLabel := label.new(bar_index + 5, currentValidLow,
                                  text=labelText,
                                  style=label.style_label_left,
                                  color=labelColor,
                                  textcolor=color.white,
                                  size=size.small)

// Nearest unbroken level labels
if nearestUnbrokenHighIndex >= 0 and nearestUnbrokenHighIndex < array.size(highs) and nearestUnbrokenHighIndex != mostRecentHighIndex
    if not na(nearestUnbrokenHighLabel)
        label.delete(nearestUnbrokenHighLabel)

    highLevel = array.get(highs, nearestUnbrokenHighIndex)
    string labelText = tf1DisplayTF + " Unbroken High"
    if highLevel.levelType == "swept"
        labelText := tf1DisplayTF + " Swept High (Unbroken)"

    nearestUnbrokenHighLabel := label.new(bar_index + 5, highLevel.price,
                                          text=labelText,
                                          style=label.style_label_left,
                                          color=color.new(highColor, 50),
                                          textcolor=color.white,
                                          size=size.small)
else
    if not na(nearestUnbrokenHighLabel)
        label.delete(nearestUnbrokenHighLabel)
        nearestUnbrokenHighLabel := na

if nearestUnbrokenLowIndex >= 0 and nearestUnbrokenLowIndex < array.size(lows) and nearestUnbrokenLowIndex != mostRecentLowIndex
    if not na(nearestUnbrokenLowLabel)
        label.delete(nearestUnbrokenLowLabel)

    lowLevel = array.get(lows, nearestUnbrokenLowIndex)
    string labelText = tf1DisplayTF + " Unbroken Low"
    if lowLevel.levelType == "swept"
        labelText := tf1DisplayTF + " Swept Low (Unbroken)"

    nearestUnbrokenLowLabel := label.new(bar_index + 5, lowLevel.price,
                                         text=labelText,
                                         style=label.style_label_left,
                                         color=color.new(lowColor, 50),
                                         textcolor=color.white,
                                         size=size.small)
else
    if not na(nearestUnbrokenLowLabel)
        label.delete(nearestUnbrokenLowLabel)
        nearestUnbrokenLowLabel := na

// ============================================================================
// ZONE RENDERING - Only on last bar for performance
// ============================================================================

renderZones(array<Zone> zones, color bgColor, color borderColor, int borderWidth, int maxZones, bool showBroken) =>
    int rendered = 0
    int arrSize = array.size(zones)
    if arrSize > 0
        for i = arrSize - 1 to 0
            if rendered >= maxZones
                break
            zone = array.get(zones, i)
            if zone.broken and not showBroken
                continue
            if not na(zone.leftTime) and not na(zone.top) and not na(zone.bottom)
                zoneEndTime = (zone.broken and not extendBrokenZones) ? zone.rightTime : time
                box.new(zone.leftTime, zone.top, zoneEndTime, zone.bottom, bgcolor=bgColor, border_color=borderColor, border_width=borderWidth, xloc=xloc.bar_time)
                rendered += 1
    rendered

if barstate.islast
    for bx in box.all
        bx.delete()

    if showTf1Zones
        renderZones(tf1DemandZones, tf1DemandZoneColor, tf1DemandZoneBorderColor, 1, maxZonesPerSide, showBrokenTf1Zones)
        renderZones(tf1SupplyZones, tf1SupplyZoneColor, tf1SupplyZoneBorderColor, 1, maxZonesPerSide, showBrokenTf1Zones)
