//@version=5
indicator("EMA Trend Cloud MTF [SB]", "ETC MTF [SB]", overlay=true)

// ============================================================================
// EMA SETTINGS
// ============================================================================
fastLen = input.int(9, "Fast EMA Length", minval=1, group="EMA Settings")
slowLen = input.int(21, "Slow EMA Length", minval=1, group="EMA Settings")
useRealtime = input.bool(false, "Use Realtime HTF Data", tooltip="When enabled, HTF clouds update with developing candle data. When disabled, HTF clouds only update on candle close (non-repainting).", group="EMA Settings")

// ============================================================================
// TIMEFRAME 1 SETTINGS
// ============================================================================
tf1Enabled = input.bool(true, "Enable TF1 Cloud", group="Timeframe 1")
tf1Timeframe = input.timeframe("", "TF1 Timeframe", group="Timeframe 1")
tf1BullColor = input.color(color.new(color.green, 95), "TF1 Bull Cloud", group="Timeframe 1")
tf1BearColor = input.color(color.new(color.red, 95), "TF1 Bear Cloud", group="Timeframe 1")

// ============================================================================
// TIMEFRAME 2 SETTINGS
// ============================================================================
tf2Enabled = input.bool(true, "Enable TF2 Cloud", group="Timeframe 2")
tf2Timeframe = input.timeframe("15", "TF2 Timeframe", group="Timeframe 2")
tf2BullColor = input.color(color.new(color.blue, 95), "TF2 Bull Cloud", group="Timeframe 2")
tf2BearColor = input.color(color.new(color.orange, 95), "TF2 Bear Cloud", group="Timeframe 2")

// ============================================================================
// TIMEFRAME 3 SETTINGS
// ============================================================================
tf3Enabled = input.bool(true, "Enable TF3 Cloud", group="Timeframe 3")
tf3Timeframe = input.timeframe("60", "TF3 Timeframe", group="Timeframe 3")
tf3BullColor = input.color(color.new(color.teal, 95), "TF3 Bull Cloud", group="Timeframe 3")
tf3BearColor = input.color(color.new(color.purple, 95), "TF3 Bear Cloud", group="Timeframe 3")

// ============================================================================
// TIMEFRAME 4 SETTINGS
// ============================================================================
tf4Enabled = input.bool(true, "Enable TF4 Cloud", group="Timeframe 4")
tf4Timeframe = input.timeframe("D", "TF4 Timeframe", group="Timeframe 4")
tf4BullColor = input.color(color.new(color.lime, 95), "TF4 Bull Cloud", group="Timeframe 4")
tf4BearColor = input.color(color.new(color.maroon, 95), "TF4 Bear Cloud", group="Timeframe 4")

// ============================================================================
// STATUS TABLE SETTINGS
// ============================================================================
showTable = input.bool(true, "Show Alignment Status", group="Status Table")
requireSlope = input.bool(true, "Require EMA Slope", tooltip="When enabled, Bull/Bear requires both EMAs sloping in the trend direction. When disabled, only checks fast vs slow EMA position.", group="Status Table")

// ============================================================================
// EMA CALCULATIONS
// ============================================================================
// Each request.security returns [fastEMA, slowEMA, prevFastEMA, prevSlowEMA, barTime]
// The [1] inside the expression refers to the previous bar on the REQUESTED timeframe
[tf1FastRaw, tf1SlowRaw, tf1FastPrevRaw, tf1SlowPrevRaw, tf1Time] = request.security(syminfo.tickerid, tf1Timeframe, [ta.ema(close, fastLen), ta.ema(close, slowLen), ta.ema(close, fastLen)[1], ta.ema(close, slowLen)[1], time])
[tf2FastRaw, tf2SlowRaw, tf2FastPrevRaw, tf2SlowPrevRaw, tf2Time] = request.security(syminfo.tickerid, tf2Timeframe, [ta.ema(close, fastLen), ta.ema(close, slowLen), ta.ema(close, fastLen)[1], ta.ema(close, slowLen)[1], time])
[tf3FastRaw, tf3SlowRaw, tf3FastPrevRaw, tf3SlowPrevRaw, tf3Time] = request.security(syminfo.tickerid, tf3Timeframe, [ta.ema(close, fastLen), ta.ema(close, slowLen), ta.ema(close, fastLen)[1], ta.ema(close, slowLen)[1], time])
[tf4FastRaw, tf4SlowRaw, tf4FastPrevRaw, tf4SlowPrevRaw, tf4Time] = request.security(syminfo.tickerid, tf4Timeframe, [ta.ema(close, fastLen), ta.ema(close, slowLen), ta.ema(close, fastLen)[1], ta.ema(close, slowLen)[1], time])

// Detect new HTF candle per timeframe (previous candle just closed)
tf1NewCandle = ta.change(tf1Time) != 0
tf2NewCandle = ta.change(tf2Time) != 0
tf3NewCandle = ta.change(tf3Time) != 0
tf4NewCandle = ta.change(tf4Time) != 0

// Confirmed-only storage: holds the last confirmed HTF values
// Only updates when a new HTF candle is detected
var float tf1FastConf = na
var float tf1SlowConf = na
var float tf1FastPrevConf = na
var float tf1SlowPrevConf = na
var float tf2FastConf = na
var float tf2SlowConf = na
var float tf2FastPrevConf = na
var float tf2SlowPrevConf = na
var float tf3FastConf = na
var float tf3SlowConf = na
var float tf3FastPrevConf = na
var float tf3SlowPrevConf = na
var float tf4FastConf = na
var float tf4SlowConf = na
var float tf4FastPrevConf = na
var float tf4SlowPrevConf = na

if tf1NewCandle
    tf1FastConf := tf1FastRaw
    tf1SlowConf := tf1SlowRaw
    tf1FastPrevConf := tf1FastPrevRaw
    tf1SlowPrevConf := tf1SlowPrevRaw

if tf2NewCandle
    tf2FastConf := tf2FastRaw
    tf2SlowConf := tf2SlowRaw
    tf2FastPrevConf := tf2FastPrevRaw
    tf2SlowPrevConf := tf2SlowPrevRaw

if tf3NewCandle
    tf3FastConf := tf3FastRaw
    tf3SlowConf := tf3SlowRaw
    tf3FastPrevConf := tf3FastPrevRaw
    tf3SlowPrevConf := tf3SlowPrevRaw

if tf4NewCandle
    tf4FastConf := tf4FastRaw
    tf4SlowConf := tf4SlowRaw
    tf4FastPrevConf := tf4FastPrevRaw
    tf4SlowPrevConf := tf4SlowPrevRaw

// Select: realtime uses developing data, confirmed waits for HTF candle close
float tf1Fast = useRealtime ? tf1FastRaw : tf1FastConf
float tf1Slow = useRealtime ? tf1SlowRaw : tf1SlowConf
float tf1FastPrev = useRealtime ? tf1FastPrevRaw : tf1FastPrevConf
float tf1SlowPrev = useRealtime ? tf1SlowPrevRaw : tf1SlowPrevConf
float tf2Fast = useRealtime ? tf2FastRaw : tf2FastConf
float tf2Slow = useRealtime ? tf2SlowRaw : tf2SlowConf
float tf2FastPrev = useRealtime ? tf2FastPrevRaw : tf2FastPrevConf
float tf2SlowPrev = useRealtime ? tf2SlowPrevRaw : tf2SlowPrevConf
float tf3Fast = useRealtime ? tf3FastRaw : tf3FastConf
float tf3Slow = useRealtime ? tf3SlowRaw : tf3SlowConf
float tf3FastPrev = useRealtime ? tf3FastPrevRaw : tf3FastPrevConf
float tf3SlowPrev = useRealtime ? tf3SlowPrevRaw : tf3SlowPrevConf
float tf4Fast = useRealtime ? tf4FastRaw : tf4FastConf
float tf4Slow = useRealtime ? tf4SlowRaw : tf4SlowConf
float tf4FastPrev = useRealtime ? tf4FastPrevRaw : tf4FastPrevConf
float tf4SlowPrev = useRealtime ? tf4SlowPrevRaw : tf4SlowPrevConf

// ============================================================================
// CLOUD STATE
// ============================================================================
tf1IsBull = tf1Fast > tf1Slow
tf2IsBull = tf2Fast > tf2Slow
tf3IsBull = tf3Fast > tf3Slow
tf4IsBull = tf4Fast > tf4Slow

// ============================================================================
// PLOTS & FILLS
// ============================================================================
// TF1
tf1FastPlot = plot(tf1Enabled ? tf1Fast : na, "TF1 Fast EMA", color=tf1IsBull ? color.new(tf1BullColor, 30) : color.new(tf1BearColor, 30), linewidth=1)
tf1SlowPlot = plot(tf1Enabled ? tf1Slow : na, "TF1 Slow EMA", color=tf1IsBull ? color.new(tf1BullColor, 30) : color.new(tf1BearColor, 30), linewidth=1)
fill(tf1FastPlot, tf1SlowPlot, color=tf1IsBull ? tf1BullColor : tf1BearColor, title="TF1 Cloud")

// TF2
tf2FastPlot = plot(tf2Enabled ? tf2Fast : na, "TF2 Fast EMA", color=tf2IsBull ? color.new(tf2BullColor, 30) : color.new(tf2BearColor, 30), linewidth=1)
tf2SlowPlot = plot(tf2Enabled ? tf2Slow : na, "TF2 Slow EMA", color=tf2IsBull ? color.new(tf2BullColor, 30) : color.new(tf2BearColor, 30), linewidth=1)
fill(tf2FastPlot, tf2SlowPlot, color=tf2IsBull ? tf2BullColor : tf2BearColor, title="TF2 Cloud")

// TF3
tf3FastPlot = plot(tf3Enabled ? tf3Fast : na, "TF3 Fast EMA", color=tf3IsBull ? color.new(tf3BullColor, 30) : color.new(tf3BearColor, 30), linewidth=1)
tf3SlowPlot = plot(tf3Enabled ? tf3Slow : na, "TF3 Slow EMA", color=tf3IsBull ? color.new(tf3BullColor, 30) : color.new(tf3BearColor, 30), linewidth=1)
fill(tf3FastPlot, tf3SlowPlot, color=tf3IsBull ? tf3BullColor : tf3BearColor, title="TF3 Cloud")

// TF4
tf4FastPlot = plot(tf4Enabled ? tf4Fast : na, "TF4 Fast EMA", color=tf4IsBull ? color.new(tf4BullColor, 30) : color.new(tf4BearColor, 30), linewidth=1)
tf4SlowPlot = plot(tf4Enabled ? tf4Slow : na, "TF4 Slow EMA", color=tf4IsBull ? color.new(tf4BullColor, 30) : color.new(tf4BearColor, 30), linewidth=1)
fill(tf4FastPlot, tf4SlowPlot, color=tf4IsBull ? tf4BullColor : tf4BearColor, title="TF4 Cloud")

// ============================================================================
// ALIGNMENT CHECK
// ============================================================================
// Bull alignment: fast > slow (and optionally both EMAs sloping upward)
// Bear alignment: fast < slow (and optionally both EMAs sloping downward)
tf1SlopeUp = tf1Fast > tf1FastPrev and tf1Slow > tf1SlowPrev
tf1SlopeDown = tf1Fast < tf1FastPrev and tf1Slow < tf1SlowPrev
tf1Bull = tf1Fast > tf1Slow and (not requireSlope or tf1SlopeUp)
tf1Bear = tf1Fast < tf1Slow and (not requireSlope or tf1SlopeDown)

tf2SlopeUp = tf2Fast > tf2FastPrev and tf2Slow > tf2SlowPrev
tf2SlopeDown = tf2Fast < tf2FastPrev and tf2Slow < tf2SlowPrev
tf2Bull = tf2Fast > tf2Slow and (not requireSlope or tf2SlopeUp)
tf2Bear = tf2Fast < tf2Slow and (not requireSlope or tf2SlopeDown)

tf3SlopeUp = tf3Fast > tf3FastPrev and tf3Slow > tf3SlowPrev
tf3SlopeDown = tf3Fast < tf3FastPrev and tf3Slow < tf3SlowPrev
tf3Bull = tf3Fast > tf3Slow and (not requireSlope or tf3SlopeUp)
tf3Bear = tf3Fast < tf3Slow and (not requireSlope or tf3SlopeDown)

tf4SlopeUp = tf4Fast > tf4FastPrev and tf4Slow > tf4SlowPrev
tf4SlopeDown = tf4Fast < tf4FastPrev and tf4Slow < tf4SlowPrev
tf4Bull = tf4Fast > tf4Slow and (not requireSlope or tf4SlopeUp)
tf4Bear = tf4Fast < tf4Slow and (not requireSlope or tf4SlopeDown)

// All enabled TFs must agree for alignment (disabled TFs are ignored)
bool anyEnabled = tf1Enabled or tf2Enabled or tf3Enabled or tf4Enabled
bool allBull = anyEnabled and (not tf1Enabled or tf1Bull) and (not tf2Enabled or tf2Bull) and (not tf3Enabled or tf3Bull) and (not tf4Enabled or tf4Bull)
bool allBear = anyEnabled and (not tf1Enabled or tf1Bear) and (not tf2Enabled or tf2Bear) and (not tf3Enabled or tf3Bear) and (not tf4Enabled or tf4Bear)

// Cloud expanding: the spread between fast and slow EMAs is growing
tf1BullExpanding = (tf1Fast - tf1Slow) > (tf1FastPrev - tf1SlowPrev)
tf1BearExpanding = (tf1Slow - tf1Fast) > (tf1SlowPrev - tf1FastPrev)

tf2BullExpanding = (tf2Fast - tf2Slow) > (tf2FastPrev - tf2SlowPrev)
tf2BearExpanding = (tf2Slow - tf2Fast) > (tf2SlowPrev - tf2FastPrev)

tf3BullExpanding = (tf3Fast - tf3Slow) > (tf3FastPrev - tf3SlowPrev)
tf3BearExpanding = (tf3Slow - tf3Fast) > (tf3SlowPrev - tf3FastPrev)

tf4BullExpanding = (tf4Fast - tf4Slow) > (tf4FastPrev - tf4SlowPrev)
tf4BearExpanding = (tf4Slow - tf4Fast) > (tf4SlowPrev - tf4FastPrev)

bool allBullExpanding = allBull and (not tf1Enabled or tf1BullExpanding) and (not tf2Enabled or tf2BullExpanding) and (not tf3Enabled or tf3BullExpanding) and (not tf4Enabled or tf4BullExpanding)
bool allBearExpanding = allBear and (not tf1Enabled or tf1BearExpanding) and (not tf2Enabled or tf2BearExpanding) and (not tf3Enabled or tf3BearExpanding) and (not tf4Enabled or tf4BearExpanding)

// Cloud contracting: the spread between fast and slow EMAs is shrinking
tf1BullContracting = (tf1Fast - tf1Slow) < (tf1FastPrev - tf1SlowPrev)
tf1BearContracting = (tf1Slow - tf1Fast) < (tf1SlowPrev - tf1FastPrev)

tf2BullContracting = (tf2Fast - tf2Slow) < (tf2FastPrev - tf2SlowPrev)
tf2BearContracting = (tf2Slow - tf2Fast) < (tf2SlowPrev - tf2FastPrev)

tf3BullContracting = (tf3Fast - tf3Slow) < (tf3FastPrev - tf3SlowPrev)
tf3BearContracting = (tf3Slow - tf3Fast) < (tf3SlowPrev - tf3FastPrev)

tf4BullContracting = (tf4Fast - tf4Slow) < (tf4FastPrev - tf4SlowPrev)
tf4BearContracting = (tf4Slow - tf4Fast) < (tf4SlowPrev - tf4FastPrev)

bool allBullContracting = allBull and (not tf1Enabled or tf1BullContracting) and (not tf2Enabled or tf2BullContracting) and (not tf3Enabled or tf3BullContracting) and (not tf4Enabled or tf4BullContracting)
bool allBearContracting = allBear and (not tf1Enabled or tf1BearContracting) and (not tf2Enabled or tf2BearContracting) and (not tf3Enabled or tf3BearContracting) and (not tf4Enabled or tf4BearContracting)

string alignment = allBullExpanding ? "Bullish Expansion" : allBearExpanding ? "Bearish Expansion" : allBullContracting ? "Bullish Contraction" : allBearContracting ? "Bearish Contraction" : allBull ? "Bullish" : allBear ? "Bearish" : "None"
color alignColor = allBull ? color.green : allBear ? color.red : color.gray

// ============================================================================
// STATUS TABLE
// ============================================================================
var table statusTable = table.new(position.bottom_right, 1, 1, bgcolor=color.new(color.black, 30), border_width=1)

if showTable
    table.cell(statusTable, 0, 0, alignment, text_color=alignColor, text_size=size.large, bgcolor=color.new(color.black, 30))
